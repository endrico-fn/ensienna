---
const links = [
  { href: "/", label: "home" },
  { href: "/gallery", label: "gallery" },
  { href: "/journey", label: "journey" },
  { href: "/about", label: "about" },
];
---

<nav>
  <ul class="flex gap-8">
    {links.map(link => (
      <li>
        <a 
          href={link.href} 
          class="text-sm tracking-widest text-white/70 hover:text-white transition-colors duration-300"
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
