---
import Base from "../layouts/Base.astro";
import { getCollection } from 'astro:content';
import FeaturedPainting from "../components/gallery/FeaturedPainting.svelte";

const paintings = await getCollection('paintings');
const featured = paintings.find(p => p.data.isFeatured) || paintings[0];
---

<Base>
  <div class="max-w-7xl mx-auto px-6 min-h-[calc(100vh-160px)] flex flex-col justify-center">
    <!-- Featured Painting Section -->
    {featured ? (
      <FeaturedPainting 
        client:load
        title={featured.data.title}
        description={featured.data.description}
        medium={featured.data.medium}
        year={featured.data.date.getFullYear()}
        imageSrc={featured.data.image.src}
        imageAlt={featured.data.title}
      />
    ) : (
      <div class="w-full max-w-sm aspect-[4/5] bg-white/5 animate-pulse"></div>
    )}

    <!-- Bottom Content (Optional if already included in redesign) -->
    <div class="mt-12 flex justify-between items-end border-t border-white/5 pt-12">
      <div class="max-w-md">
        <h2 class="text-2xl text-white/40 leading-tight font-light serif italic">
          every painting is an<br />
          <span class="not-italic text-white/60">honest record</span>
        </h2>
      </div>
      <div>
        <a href="/journey" class="group flex items-center gap-4 text-xs tracking-widest uppercase text-sienna hover:text-sienna/80 transition-colors duration-300">
          read the journey
          <span class="text-lg transition-transform duration-300 group-hover:translate-x-2">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</Base>
