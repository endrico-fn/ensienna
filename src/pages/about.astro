---
import Base from "../layouts/Base.astro";
---

<Base title="About Me — ensienna">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <h1 class="text-4xl font-light serif mb-12">About Me</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-white/80 leading-relaxed mb-6">
          Hello, I'm an artist specializing in oil paintings and digital illustrations. 
          My work explores the intersection of traditional techniques and modern themes.
        </p>
        <p class="text-white/80 leading-relaxed">
          Through this gallery, I share my creative journey and the evolution of my style. 
          Each piece tells a unique story, captured through brushstrokes and color.
        </p>
      </div>
      <div class="aspect-square bg-white/5 border border-white/10 rounded-lg flex items-center justify-center">
        <span class="text-white/20">Profile Image</span>
      </div>
    </div>
  </div>
</Base>
